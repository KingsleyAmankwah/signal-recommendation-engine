{#
/**
 * @file
 * Hero component.
 *
 * Lead banner for a full article: optional media, tags, the H1 headline and a
 * meta row. Slots are declared as Twig blocks so callers can fill them with
 * either the `#slots` render property or an `{% embed %}` block override; the
 * printed variable inside each block is the default when nothing is provided.
 */
#}
{% set variant = variant|default('default') %}
{% set hero_attributes = attributes.addClass('hero', 'hero--' ~ variant) %}
{% set media_content %}{% block media %}{{ media }}{% endblock %}{% endset %}
{% set tags_content %}{% block tags %}{{ tags }}{% endblock %}{% endset %}
{% set meta_content %}{% block meta %}{{ meta }}{% endblock %}{% endset %}
<header{{ hero_attributes }}>
  {% if media_content|trim is not empty %}
    <div class="hero__media">{{ media_content }}</div>
  {% endif %}
  <div class="hero__content">
    {% if tags_content|trim is not empty %}
      <div class="hero__tags">{{ tags_content }}</div>
    {% endif %}
    <h1 class="hero__title">{{ title }}</h1>
    {% if meta_content|trim is not empty %}
      <div class="hero__meta">{{ meta_content }}</div>
    {% endif %}
  </div>
</header>
